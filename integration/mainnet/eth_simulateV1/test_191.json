[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-check-that-nonce-increases.io",
            "description": "nonce increases across successive calls in blockStateCalls - executed on historical block"
        },
        "request": {
            "jsonrpc": "2.0",
            "id": 1,
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "blockOverrides": {
                                "baseFeePerGas": "0x9"
                            },
                            "stateOverrides": {
                                "0xc000000000000000000000000000000000000000": {
                                    "balance": "0x4a817c800"
                                }
                            },
                            "calls": [
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc000000000000000000000000000000000000000",
                                    "maxFeePerGas": "0xf",
                                    "nonce": "0x0"
                                },
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc000000000000000000000000000000000000000",
                                    "maxFeePerGas": "0xf",
                                    "nonce": "0x1"
                                },
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc000000000000000000000000000000000000000",
                                    "maxFeePerGas": "0xf",
                                    "nonce": "0x2"
                                }
                            ]
                        }
                    ],
                    "validation": true
                },
                "0x1406f40"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0",
            "result": "0x3"
        }
    }
]
