[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-transaction-too-high-nonce.io",
            "description": "nonce=0x64 on fresh account, no validation: tx succeeds (nonce too high is only enforced with validation:true)"
        },
        "request": {
            "id": 1,
            "jsonrpc": "2.0",
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "calls": [
                                {
                                    "from": "0xc100000000000000000000000000000000000000",
                                    "to": "0xc100000000000000000000000000000000000000",
                                    "nonce": "0x64"
                                }
                            ]
                        }
                    ]
                },
                "latest"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0"
        },
        "metadata": {
            "latest": true
        }
    }
]
