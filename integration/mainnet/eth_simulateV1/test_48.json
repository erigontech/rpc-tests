[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-send-eth-and-delegate-call-to-eoa.io",
            "description": "delegatecall to EOA with ETH and traceTransfers:true: produces exactly one Transfer log (sender\u2192contract, contract delegatecalls EOA which has no code)"
        },
        "request": {
            "id": 1,
            "jsonrpc": "2.0",
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "stateOverrides": {
                                "0xc000000000000000000000000000000000000000": {
                                    "balance": "0x1e8480"
                                },
                                "0xc100000000000000000000000000000000000000": {
                                    "code": ""
                                }
                            },
                            "calls": [
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc100000000000000000000000000000000000000",
                                    "value": "0x3e8",
                                    "input": "0x"
                                }
                            ]
                        }
                    ],
                    "traceTransfers": true
                },
                "latest"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0"
        },
        "metadata": {
            "latest": true
        }
    }
]
