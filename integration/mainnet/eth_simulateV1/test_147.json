[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-move-two-accounts-to-same-38023.io",
            "description": "MovePrecompileToAddress: two different precompiles (ecrecover 0x1, sha256 0x2) moved to the same destination address - executed on historical block"
        },
        "request": {
            "id": 1,
            "jsonrpc": "2.0",
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "stateOverrides": {
                                "0x0000000000000000000000000000000000000001": {
                                    "MovePrecompileToAddress": "0xc200000000000000000000000000000000000000"
                                },
                                "0x0000000000000000000000000000000000000002": {
                                    "MovePrecompileToAddress": "0xc200000000000000000000000000000000000000"
                                }
                            }
                        }
                    ]
                },
                "0x1406f40"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0",
            "result": "0x3"
        }
    }
]
