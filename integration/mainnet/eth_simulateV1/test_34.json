[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-eth-send-should-not-produce-logs-on-revert.io",
            "description": "ETH transfer to reverting contract with traceTransfers:true: call reverts, no ETH moved, logs must be empty"
        },
        "request": {
            "id": 1,
            "jsonrpc": "2.0",
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "stateOverrides": {
                                "0xc000000000000000000000000000000000000000": {
                                    "balance": "0x7d0"
                                },
                                "0xc100000000000000000000000000000000000000": {
                                    "code": ""
                                }
                            },
                            "calls": [
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc100000000000000000000000000000000000000",
                                    "value": "0x3e8"
                                }
                            ]
                        }
                    ],
                    "traceTransfers": true,
                    "returnFullTransactions": true
                },
                "latest"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0"
        },
        "metadata": {
            "latest": true
        }
    }
]
