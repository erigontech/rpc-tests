[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-overflow-nonce.io",
            "description": "nonce overridden to max uint64 (0xffffffffffffffff) without validation: both calls succeed (nonce wraps or is ignored)"
        },
        "request": {
            "id": 1,
            "jsonrpc": "2.0",
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "stateOverrides": {
                                "0xc000000000000000000000000000000000000000": {
                                    "nonce": "0xffffffffffffffff"
                                }
                            },
                            "calls": [
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc100000000000000000000000000000000000000"
                                },
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc100000000000000000000000000000000000000"
                                }
                            ]
                        }
                    ]
                },
                "latest"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0"
        },
        "metadata": {
            "latest": true
        }
    }
]
