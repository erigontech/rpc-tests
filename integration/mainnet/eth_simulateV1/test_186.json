[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-block-override-reflected-in-contract-simple.io",
            "description": "simple block override (number) visible inside contract via BLOCKNUMBER opcode - executed on historical block"
        },
        "request": {
            "jsonrpc": "2.0",
            "id": 1,
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "blockOverrides": {
                                "number": "0x32",
                                "time": "0x1cc"
                            }
                        },
                        {
                            "blockOverrides": {
                                "number": "0x37",
                                "time": "0x1d6"
                            }
                        },
                        {
                            "blockOverrides": {
                                "number": "0x41",
                                "time": "0x1e0"
                            }
                        }
                    ]
                },
                "0x1406f40"
            ]
        },
        "response": {
            "error": {
                "code": -38020,
                "message": "block numbers must be in order: 50 <= 21000000"
            },
            "id": 1,
            "jsonrpc": "2.0"
        },
        "metadata": {
            "requestCommittedHistory": true
        }
    }
]
