[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-instrict-gas-38013.io",
            "description": "call with gas below intrinsic gas cost \u2192 error -38013 - executed on historical block"
        },
        "request": {
            "jsonrpc": "2.0",
            "id": 1,
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "calls": [
                                {
                                    "from": "0xc100000000000000000000000000000000000000",
                                    "to": "0xc100000000000000000000000000000000000000",
                                    "gas": "0x0"
                                }
                            ]
                        }
                    ]
                },
                "0x1406f40"
            ]
        },
        "response": {
            "error": {
                "code": -38013,
                "message": "err: intrinsic gas too low: have 0, want 21000 (supplied gas 0)"
            },
            "id": 1,
            "jsonrpc": "2.0"
        }
    }
