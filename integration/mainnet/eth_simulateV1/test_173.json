[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-precompile-is-sending-transaction.io",
            "description": "send transaction from precompile 0x4 (identity) to precompile 0x2 (sha256) with input 0x1234: succeeds, returns sha256 hash - executed on historical block"
        },
        "request": {
            "id": 1,
            "jsonrpc": "2.0",
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "calls": [
                                {
                                    "from": "0x0000000000000000000000000000000000000004",
                                    "to": "0x0000000000000000000000000000000000000002",
                                    "input": "0x1234"
                                }
                            ]
                        }
                    ]
                },
                "0x1406f40"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0",
            "result": "0x3"
        }
    }
]
