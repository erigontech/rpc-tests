[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-simple-validation-fulltx.io",
            "description": "simple call with validation:true and returnFullTransactions:true \u2192 full tx in result"
        },
        "request": {
            "jsonrpc": "2.0",
            "id": 1,
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "blockOverrides": {
                                "baseFeePerGas": "0xf"
                            },
                            "stateOverrides": {
                                "0xc000000000000000000000000000000000000000": {
                                    "balance": "0xe8d4a51000"
                                }
                            },
                            "calls": [
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc100000000000000000000000000000000000000",
                                    "maxFeePerGas": "0x10",
                                    "value": "0x2540be400"
                                },
                                {
                                    "from": "0xc100000000000000000000000000000000000000",
                                    "to": "0xc200000000000000000000000000000000000000",
                                    "maxFeePerGas": "0x10",
                                    "value": "0x3e8"
                                }
                            ]
                        }
                    ],
                    "validation": true,
                    "returnFullTransactions": true
                },
                "latest"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0"
        },
        "metadata": {
            "latest": true
        }
    }
]
