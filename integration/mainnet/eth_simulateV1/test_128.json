[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-simple.io",
            "description": "minimal ETH transfer with balance override \u2192 success - executed on historical block"
        },
        "request": {
            "jsonrpc": "2.0",
            "id": 1,
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "stateOverrides": {
                                "0xc000000000000000000000000000000000000000": {
                                    "balance": "0x3e8"
                                }
                            },
                            "calls": [
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc100000000000000000000000000000000000000",
                                    "value": "0x3e8"
                                },
                                {
                                    "from": "0xc100000000000000000000000000000000000000",
                                    "to": "0xc200000000000000000000000000000000000000",
                                    "value": "0x3e8"
                                }
                            ]
                        }
                    ]
                },
                "0x1406f40"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0",
            "result": "0x3"
        }
    }
]
