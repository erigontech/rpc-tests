[
    {
        "test": {
            "reference": "https://github.com/ethereum/execution-apis/blob/main/tests/eth_simulateV1/ethSimulate-eth-send-should-produce-logs.io",
            "description": "ETH transfer with traceTransfers:true: produces one ERC20-like Transfer log at 0xeeee... from sender to recipient - executed on historical block"
        },
        "request": {
            "id": 1,
            "jsonrpc": "2.0",
            "method": "eth_simulateV1",
            "params": [
                {
                    "blockStateCalls": [
                        {
                            "stateOverrides": {
                                "0xc000000000000000000000000000000000000000": {
                                    "balance": "0x7d0"
                                }
                            },
                            "calls": [
                                {
                                    "from": "0xc000000000000000000000000000000000000000",
                                    "to": "0xc100000000000000000000000000000000000000",
                                    "value": "0x3e8"
                                }
                            ]
                        }
                    ],
                    "traceTransfers": true
                },
                "0x1406f40"
            ]
        },
        "response": {
            "id": 1,
            "jsonrpc": "2.0",
            "result": "0x3"
        }
    }
]
